# AWS Configuration
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# AI Models (Bedrock)
NOVA_LITE_MODEL_ID=amazon.nova-lite-v2:0
NOVA_SONIC_MODEL_ID=amazon.nova-sonic-v2:0
NOVA_ACT_MODEL_ID=amazon.nova-act-v1:0
NOVA_MULTIMODAL_EMBEDDING_MODEL_ID=amazon.nova-multimodal-embedding-v1:0

# Storage Settings
S3_BUCKET_NAME=omniaccess-assets
DYNAMODB_TABLE_NAME=OmniAccessMemory

# Security & API
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SECURITY_REQUIRE_AUTH=true
SECURITY_API_KEYS=dev-key
SECURITY_ALLOW_DEV_HEADERS=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120

# Local Data Paths
VECTOR_DB_PATH=./data/chroma
UPLOADS_DIR=./uploads
